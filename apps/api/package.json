{
  "name": "@qmenut/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./router": {
      "types": "./src/trpc/router.ts",
      "import": "./src/trpc/router.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev --port 8787 --inspector-port 9230",
    "build": "wrangler types && tsc --noEmit",
    "check": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrations:list": "wrangler d1 migrations list DB --remote",
    "db:seed:local": "wrangler d1 execute DB --local --file seed/seed-public-menu.sql",
    "tenant:create": "bun scripts/create-tenant.ts"
  },
  "dependencies": {
    "@qmenut/auth": "workspace:*",
    "@qmenut/db": "workspace:*",
    "@qmenut/ui": "workspace:*",
    "@sentry/cloudflare": "^10.63.0",
    "@trpc/server": "11.18.0",
    "stripe": "^19",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.0",
    "@types/bun": "^1.3.6",
    "@types/node": "^26.0.1",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.9.3",
    "wrangler": "^4.60.0"
  }
}
