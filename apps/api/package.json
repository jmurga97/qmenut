{
  "name": "@qmenut/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787 --inspector-port 9230",
    "build": "wrangler types && tsc --noEmit",
    "check": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "db:migrations:list": "wrangler d1 migrations list DB --remote"
  },
  "dependencies": {
    "@trpc/server": "11.18.0",
    "better-auth": "1.6.23",
    "drizzle-orm": "^0.44.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^26.0.1",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.9.3",
    "wrangler": "^4.60.0"
  }
}
