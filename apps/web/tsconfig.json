{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "paths": {
      "~/*": ["./src/*"],
      "~/app/*": ["./src/app/*"],
      "~/components/*": ["./src/shared/components/*"],
      "~/features/*": ["./src/features/*"],
      "~/lib/*": ["./src/lib/*"],
      "~/shared/*": ["./src/shared/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
